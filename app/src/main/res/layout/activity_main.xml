<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E17">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_launcher"
                app:tint="#38BDF8" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mosque TV / مساجد"
                    android:textSize="28sp"
                    android:textColor="#F8FAFC"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نظام التحكم السحابي المتطور"
                    android:textSize="14sp"
                    android:textColor="#94A3B8" />
            </LinearLayout>
        </LinearLayout>

        <!-- Main Content -->
        <!-- Pairing Layout -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutPairing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#111827"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗 ربط الجهاز"
                    android:textSize="20sp"
                    android:textColor="#F1F5F9"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/etPairingCode"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:hint="000 000"
                    android:textSize="40sp"
                    android:textColor="#38BDF8"
                    android:textColorHint="#1E293B"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="6"
                    android:background="@android:color/transparent"
                    android:letterSpacing="0.4"
                    android:layout_marginBottom="20dp"/>

                <Button
                    android:id="@+id/btnPair"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="تفعيل الرابط"
                    android:textSize="18sp"
                    android:backgroundTint="#38BDF8"
                    android:textColor="#0A0E17"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Paired Layout -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutPaired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#064E3B"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الجهاز متصل بنجاح ✅"
                    android:textSize="20sp"
                    android:textColor="#ECFDF5"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnUnpair"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="قطع الاتصال"
                    android:backgroundTint="#EF4444"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Countdown Layout -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutAutoLaunch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#451A03"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سيتم إطلاق القناة قريباً..."
                    android:textSize="16sp"
                    android:textColor="#FDE68A"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnCancelAutoLaunch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إلغاء التشغيل التلقائي"
                    android:backgroundTint="#78350F"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#111827">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏰ التشغيل"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvWakeTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textSize="28sp"
                        android:textColor="#10B981"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#111827">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 الإيقاف"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvSleepTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textSize="28sp"
                        android:textColor="#F43F5E"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Control Buttons -->
        <Button
            android:id="@+id/btnSyncCloud"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="☁️ مزامنة فورية مع السحابة"
            android:textSize="18sp"
            android:backgroundTint="#0EA5E9"
            app:cornerRadius="18dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnSelectApp"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="📺 إعدادات القناة والتحكم"
            android:textSize="18sp"
            android:backgroundTint="#8B5CF6"
            app:cornerRadius="18dp"
            android:layout_marginBottom="40dp" />

        <!-- Footer Info -->
        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔵 بانتظار الاتصال بالخادم..."
            android:textSize="14sp"
            android:textColor="#38BDF8"
            android:letterSpacing="0.05" />

    </LinearLayout>
</ScrollView>
