<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نظام المسجد الآلي السحابي"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnSyncCloud"
            android:layout_width="350dp"
            android:layout_height="70dp"
            android:text="مزامنة الإعدادات من السحابة الآن"
            android:textSize="20sp"
            android:backgroundTint="#03A9F4"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="30dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="وقت التشغيل (إيقاظ):"
                    android:textColor="#BBBBBB"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tvWakeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="50sp"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="وقت الإطفاء (سكون):"
                    android:textColor="#BBBBBB"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tvSleepTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="50sp"
                    android:textColor="#F44336"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تطبيق التلفاز المبرمج للتشغيل:"
            android:textColor="#BBBBBB"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvAppPackage"
            android:layout_width="350dp"
            android:layout_height="50dp"
            android:text="com.google.android.youtube"
            android:gravity="center"
            android:textColor="#FFEB3B"
            android:textSize="18sp"
            android:background="#333333"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnEnableAdmin"
            android:layout_width="350dp"
            android:layout_height="50dp"
            android:text="تفعيل صلاحية مسؤول الجهاز للإطفاء التلقائي"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
